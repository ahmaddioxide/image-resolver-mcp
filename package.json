{
  "name": "mcp-image-resolver",
  "version": "0.2.0",
  "description": "MCP server for context-aware royalty-free image search from Pexels and Unsplash",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/image-mcp.git"
  },
